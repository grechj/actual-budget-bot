# AB Bot local storage
AB_BOT_DATA_DIR=.ab-bot/actual-data

# Local web UI
AB_BOT_WEB_HOST=127.0.0.1
AB_BOT_WEB_PORT=3000

# Actual Budget sync server
# Start Actual locally, then copy the Sync ID from Settings -> Advanced.
ACTUAL_SERVER_URL=http://localhost:5006
ACTUAL_PASSWORD=
ACTUAL_BUDGET_ID=
ACTUAL_BUDGET_PASSWORD=

# AI provider
# "disabled" keeps all AI chat off. Use "ollama" for local AI or "openai" for cloud AI.
AB_BOT_AI_PROVIDER=disabled
AB_BOT_AI_MODEL=

# OpenAI cloud AI. Only set this if you are comfortable sending summaries/context to OpenAI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# Ollama local AI. Run Ollama separately and pull the selected model first.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OCR
# macOS tries Apple Vision first. Tesseract is used as a fallback when installed.
SWIFT_BIN=/usr/bin/swift
TESSERACT_BIN=tesseract
TESSERACT_LANG=eng
